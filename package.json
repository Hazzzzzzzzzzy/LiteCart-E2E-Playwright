{
  "name": "litecart-playwright-tests",
  "version": "1.0.0",
  "description": "E2E LiteCart",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:allure": "playwright test --reporter=list,allure-playwright",
    "allure:report": "allure generate allure-results -o allure-report --clean && allure open allure-report"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "allure-playwright": "^3.0.0",
    "typescript": "^5.6.0"
  }
}
